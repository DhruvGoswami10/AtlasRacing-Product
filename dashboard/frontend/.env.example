# Atlas Racing - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env or .env.local to version control

# Server port (default: 3000)
PORT=3000
BROWSER=none

# OpenAI API Configuration (required for LLM Race Engineer)
# Get your API key from: https://platform.openai.com/api-keys
REACT_APP_OPENAI_API_KEY=your_openai_api_key_here
REACT_APP_OPENAI_MODEL=gpt-4o-mini

# Supabase Configuration (optional - for cloud features)
# Get your keys from: https://supabase.com/dashboard
REACT_APP_SUPABASE_URL=your_supabase_url_here
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here
