{
  "name": "atlas-racing-dashboard",
  "version": "1.0.0",
  "description": "Atlas Racing desktop companion for live telemetry dashboards.",
  "main": "electron/main.js",
  "homepage": "./",
  "private": true,
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.76.1",
    "@tailwindcss/forms": "^0.5.3",
    "@types/node": "^18.15.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@types/react-grid-layout": "^1.3.5",
    "autoprefixer": "^10.4.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.23.3",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.21",
    "qrcode": "^1.5.4",
    "qrcode.js": "^0.0.1",
    "react": "^18.2.0",
    "react-day-picker": "^9.9.0",
    "react-dom": "^18.2.0",
    "react-draggable": "^4.5.0",
    "react-grid-layout": "^1.5.2",
    "react-hook-form": "^7.62.0",
    "react-resizable-panels": "^3.0.4",
    "react-router-dom": "^7.6.3",
    "react-scripts": "5.0.1",
    "recharts": "^2.15.4",
    "socket.io-client": "^4.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.2.7",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^4.9.5",
    "uiohook-napi": "^1.5.4",
    "vaul": "^1.1.2",
    "zustand": "^4.3.6"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "electron": "^23.3.13",
    "electron-builder": "^23.6.0",
    "wait-on": "^7.0.1"
  },
  "scripts": {
    "start": "set BROWSER=none&& react-scripts start",
    "start-windows": "set BROWSER=none&& react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run start-windows\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-pack": "npm run build && electron-builder",
    "preelectron-pack": "npm run build"
  },
  "build": {
    "appId": "com.atlasracing.dashboard",
    "productName": "Atlas Racing Dashboard",
    "directories": {
      "output": "dist",
      "buildResources": "buildResources"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "buildResources/**/*"
    ],
    "mac": {
      "category": "public.app-category.sports",
      "target": "dmg",
      "icon": "icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico",
      "artifactName": "AtlasRacing-${version}-Setup.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icon-256.png",
      "category": "Utility",
      "artifactName": "AtlasRacing-${version}.${ext}"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
