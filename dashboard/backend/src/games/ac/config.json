{
  "name": "Assetto Corsa",
  "executable": "acs.exe",
  "telemetry_method": "shared_memory",
  "shared_memory_files": [
    "Local\\acpmf_physics",
    "Local\\acpmf_graphics", 
    "Local\\acpmf_static"
  ],
  "parser_class": "AC_Parser",
  "available_dashboards": ["minimal", "professional", "ac-trackday", "ac-hotlap", "builder"],
  "specific_widgets": ["detailed-tire", "performance-meter", "track-conditions", "suspension"],
  "update_rate": "real-time",
  "connection": {
    "protocol": "shared_memory",
    "requires_setup": false,
    "automatic_detection": true
  },
  "features": {
    "detailed_tire_data": true,
    "suspension_travel": true,
    "performance_meter": true,
    "track_conditions": true,
    "engine_data": true,
    "brake_temperatures": true,
    "aerodynamics": true
  }
}